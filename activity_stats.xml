<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="#ffffff">

    <TextView
        android:id="@+id/statsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📊 Admin Dashboard Stats"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/totalUsers"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Total Users: ..."
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@+id/statsTitle"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="24dp" />

    <TextView
        android:id="@+id/totalAdmins"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Total Admins: ..."
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@+id/totalUsers"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp" />

    <TextView
        android:id="@+id/totalRegularUsers"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Regular Users: ..."
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@+id/totalAdmins"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp" />
</androidx.constraintlayout.widget.ConstraintLayout>
